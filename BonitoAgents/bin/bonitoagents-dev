#!/usr/bin/env bash
# bonitoagents-dev — self-contained server + local worker for development.
#
# No systemd, no install steps, no shared state. Everything lives in
# mktempdir() folders that get rm-rf'd on Ctrl+C. Uses the current
# working directory's Julia project (./Project.toml), matching the rest
# of the dev workflow.
#
# Usage:
#   cd /path/to/your/project   # must have BonitoAgents dev'd in
#   bonitoagents-dev             # picks a free port, prints the URL
#   bonitoagents-dev --port 8138 # pin a specific port
#   bonitoagents-dev --open      # also open the dashboard in your browser
set -euo pipefail

OPEN_FLAG="false"
PORT_ARG=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --open)   OPEN_FLAG="true"; shift ;;
        --port)   PORT_ARG=", port = $2"; shift 2 ;;
        --help|-h)
            sed -n '2,15p' "$0"; exit 0 ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Try --help" >&2
            exit 1 ;;
    esac
done

exec julia --project=. --startup-file=no --threads=auto \
    -e "using BonitoAgents; \
        BonitoAgents.dev_server(; auto_open = $OPEN_FLAG$PORT_ARG) do h; \
            BonitoAgents.wait!(h); \
        end"
