#!/usr/bin/env bash
# Thin wrapper so `LocalTransport.agent_bin = .../mock_claude_agent_acp`
# can stay a plain executable path: the production transport spawns the
# agent via `Cmd(`$(t.agent_bin)`)`, which doesn't carry args, so we exec
# Julia from here with the right project + the mock .jl alongside.
#
# The `BT_MOCK_ACP_*` env vars are passed through by the test's
# `agent_env` Dict on `LocalTransport`, so the scenario / chunk count /
# pacing are entirely the test's call.
set -eu

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Tests can override the Julia binary (multi-version setups) and the
# project the mock activates (default: the BonitoAgents test project).
: "${BT_MOCK_JULIA:=julia}"
: "${BT_MOCK_PROJECT:=$HERE/../..}"

# --startup-file=no shaves ~150 ms off cold start, which adds up across a
# stress suite that respawns the mock per restart.
exec "$BT_MOCK_JULIA" \
    --startup-file=no --color=no --history-file=no \
    --project="$BT_MOCK_PROJECT" \
    "$HERE/mock_claude_agent_acp.jl" "$@"
