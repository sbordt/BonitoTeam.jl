#!/usr/bin/env bash
# Standalone wrapper for BonitoMCP stdio server.
#
# Configure in Claude Code (~/.claude.json mcpServers):
#   "bonitoteam": {
#     "type": "stdio",
#     "command": "/path/to/BonitoMCP/bin/bonitoteam-mcp"
#   }
#
# Cold start (first run): ~5-15s while Julia precompiles BonitoMCP.
# Subsequent starts: ~1-3s from the precompile cache.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

exec julia \
    "--project=${PROJECT_DIR}" \
    --startup-file=no \
    --threads=auto \
    -e 'using BonitoMCP; BonitoMCP.run_stdio()'
