#!/usr/bin/env bash
# Standalone wrapper for BonitoMCP stdio server.
#
# Configure in Claude Code (~/.claude.json mcpServers):
#   "bonitoteam": {
#     "type": "stdio",
#     "command": "/path/to/BonitoMCP/bin/bonitoteam-mcp"
#   }
#
# Cold start (first run): ~5-15s while Julia precompiles BonitoMCP.
# Subsequent starts: ~1-3s from the precompile cache.
set -euo pipefail
# Resolve symlinks so we find the bundle dir even when invoked via
# ~/.local/bin/bonitoteam-mcp (a symlink the installer creates).
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PACKAGE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
# Operational env is the parent of the package dir, never the package's own
# Project.toml. On a worker that's $INSTALL_ROOT; in dev that's the monorepo
# root. The package's own Project.toml is metadata for declaring deps only.
PROJECT_DIR="$(cd "${PACKAGE_DIR}/.." && pwd)"

exec julia \
    "--project=${PROJECT_DIR}" \
    --startup-file=no \
    --threads=auto \
    -e 'using BonitoMCP; BonitoMCP.run_stdio()'
