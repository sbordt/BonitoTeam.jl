#!/usr/bin/env bash
# BonitoWorker — outbound-only WS relay. Dials the BonitoTeam server.
#
# Env:
#   BONITOTEAM_WORKER_SECRET   shared secret for auth (required)
#   BONITOTEAM_SERVER_URL      e.g. http://server:8038 (required)
#   BONITOTEAM_WORKER_NAME     display name (default: hostname)
#   BONITOTEAM_PROJECTS_ROOT   root for rsync'd projects (default: ~/bonitoteam-projects)
#   BONITOTEAM_MCP_BIN         path to bonitoteam-mcp (default: ../BonitoMCP/bin/bonitoteam-mcp)
#   CLAUDE_AGENT_ACP           path to claude-agent-acp binary (auto-detected via PATH)
set -euo pipefail

# Resolve symlinks so we find the bundle dir even when invoked via
# ~/.local/bin/bonitoteam-worker (a symlink the installer creates).
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PACKAGE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
# Operational env is the parent of the package dir, never the package's own
# Project.toml. Layout matches the server's monorepo: env Project.toml +
# Manifest.toml live at the parent, with [sources] paths pointing at sibling
# packages. On a worker that's $INSTALL_ROOT (= $HOME/.local/share/bonitoteam);
# in dev that's the monorepo root.
PROJECT_DIR="$(cd "${PACKAGE_DIR}/.." && pwd)"

if [[ -z "${BONITOTEAM_WORKER_SECRET:-}" ]]; then
    echo "ERROR: BONITOTEAM_WORKER_SECRET must be set" >&2
    exit 1
fi
if [[ -z "${BONITOTEAM_SERVER_URL:-}" ]]; then
    echo "ERROR: BONITOTEAM_SERVER_URL must be set" >&2
    exit 1
fi

# Default MCP path to the sibling BonitoMCP/bin/bonitoteam-mcp wrapper
export BONITOTEAM_MCP_BIN="${BONITOTEAM_MCP_BIN:-${PROJECT_DIR}/BonitoMCP/bin/bonitoteam-mcp}"

exec julia \
    "--project=${PROJECT_DIR}" \
    --startup-file=no \
    --threads=auto \
    "${PACKAGE_DIR}/src/worker_standalone.jl"
